# Prisma Postgres connection URL for local development.
# Prisma Compute can wire this automatically for deployments.
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=replace_me"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboarding"

# Required for US stock market data through Alpaca.
ALPACA_API_KEY_ID=""
ALPACA_API_SECRET_KEY=""

# Crypto market data uses Binance public endpoints and does not need an API key.
